# 大模型 API 密钥配置
volcengine_API_KEY="您的火山引擎(豆包)API密钥"
DEEPSEEK_API_KEY="您的DeepSeek-API密钥"

# 外部工具 API 密钥配置
QWEATHER_API_KEY="您的和风天气API密钥"
AMAP_API_KEY="您的高德地图Web服务API Key"
TAVILY_API_KEY="您的Tavily Search API Key(可选，用于网页搜索引擎)"

